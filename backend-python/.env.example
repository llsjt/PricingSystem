APP_ENV=dev
APP_NAME=pricing-agent-backend
APP_PORT=8000

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=pricing_system2.0
MYSQL_USER=root
MYSQL_PASSWORD=123456

INTERNAL_API_TOKEN=
PYTHON_BASE_PREFIX=/internal

# 如需接入真实 LLM，可配置以下参数（当前最小可运行版不依赖）
DASHSCOPE_API_KEY=
AGENT_MODEL=qwen-plus

# 市场分析默认使用模拟竞品数据
MARKET_SIMULATION_ENABLED=true

# 关闭 CrewAI 遥测，避免离线环境超时
CREWAI_DISABLE_TELEMETRY=true
OTEL_SDK_DISABLED=true
