APP_ENV=dev
APP_NAME=pricing-agent-backend
APP_PORT=8000

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=pricing_system2.0
MYSQL_USER=root
MYSQL_PASSWORD=123456

INTERNAL_API_TOKEN=
PYTHON_BASE_PREFIX=/internal

# OpenAI-compatible LLM config
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen3.5-plus

# Per-call timeout and retry control
LLM_TIMEOUT_SECONDS=60
LLM_CONNECT_TIMEOUT_SECONDS=8
LLM_READ_TIMEOUT_SECONDS=25
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF_SECONDS=1.2

# CrewAI-specific LLM budget (recommended to be tighter than global LLM budget)
CREWAI_LLM_TIMEOUT_SECONDS=28
CREWAI_LLM_CONNECT_TIMEOUT_SECONDS=5
CREWAI_LLM_READ_TIMEOUT_SECONDS=18
CREWAI_LLM_MAX_RETRIES=0

# CrewAI MVP orchestration budget
CREWAI_MVP_ENABLED=true
CREWAI_AGENT_MAX_ITER=2
CREWAI_AGENT_MAX_EXEC_SECONDS=20
CREWAI_AGENT_MAX_RETRY_LIMIT=0
CREWAI_SESSION_TIMEOUT_SECONDS=45
CREWAI_ENABLE_SECOND_ROUND=false

# Market intel currently uses simulated competitor samples
MARKET_SIMULATION_ENABLED=true

# Disable telemetry for local/offline stability
CREWAI_DISABLE_TELEMETRY=true
OTEL_SDK_DISABLED=true
