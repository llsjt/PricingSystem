APP_ENV=dev
APP_NAME=pricing-agent-backend
APP_PORT=8000

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=pricing_system2.0
MYSQL_USER=root
MYSQL_PASSWORD=123456

INTERNAL_API_TOKEN=
PYTHON_BASE_PREFIX=/internal

# OpenAI-compatible LLM config
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen3.5-plus

# Per-call timeout and retry control
LLM_TIMEOUT_SECONDS=60
LLM_CONNECT_TIMEOUT_SECONDS=8
LLM_READ_TIMEOUT_SECONDS=25
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF_SECONDS=1.2

# CrewAI LLM 调用超时（每次 LLM API 调用的超时限制）
CREWAI_LLM_TIMEOUT_SECONDS=60
CREWAI_LLM_CONNECT_TIMEOUT_SECONDS=8
CREWAI_LLM_READ_TIMEOUT_SECONDS=30
CREWAI_LLM_MAX_RETRIES=1

# CrewAI Agent 执行参数（4个Agent串行，需要足够时间和迭代次数）
CREWAI_MVP_ENABLED=true
CREWAI_AGENT_MAX_ITER=5
CREWAI_AGENT_MAX_EXEC_SECONDS=60
CREWAI_AGENT_MAX_RETRY_LIMIT=1
CREWAI_SESSION_TIMEOUT_SECONDS=300
CREWAI_ENABLE_SECOND_ROUND=false

# Market intel currently uses simulated competitor samples
MARKET_SIMULATION_ENABLED=true

# Disable telemetry for local/offline stability
CREWAI_DISABLE_TELEMETRY=true
OTEL_SDK_DISABLED=true
