APP_ENV=dev
APP_NAME=pricing-agent-backend
APP_PORT=8000

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=pricing_system2.0
MYSQL_USER=root
MYSQL_PASSWORD=123456

INTERNAL_API_TOKEN=
PYTHON_BASE_PREFIX=/internal

# CrewAI 调用真实大模型（OpenAI 兼容协议）
LLM_API_KEY=sk-6b2b6fb3c168482c9c3f54c84e0b1674
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen3.5-plus
