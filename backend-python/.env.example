# ============================================================
#  需要手动配置的项（必填）
# ============================================================

# [必填] MySQL 密码 —— 改成你本机 MySQL root 用户的密码
MYSQL_PASSWORD=replace-with-dev-password

# [必填] Java ↔ Python 内部通信 Token
#        开发环境留空即可自动跳过验证（需 ALLOW_DEV_INTERNAL_TOKEN_BYPASS=true）
#        生产环境必须设一个随机字符串，且与 Java 端 application.yml 中的值保持一致
INTERNAL_API_TOKEN=

# [生产必填] 用户 API Key 在 pricing_task 表中的 Fernet 加密密钥
#            开发环境留空则明文透传；生产环境必须设置一个随机字符串
LLM_KEY_ENCRYPTION_SECRET=

# ============================================================
#  以下配置一般保持默认即可，无需修改
# ============================================================

# 基础应用配置
APP_ENV=dev
APP_NAME=pricing-agent-backend
APP_PORT=8000

# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=pricing_system2.0
MYSQL_USER=root

# 内部调用与任务队列配置
ALLOW_DEV_INTERNAL_TOKEN_BYPASS=true
PYTHON_BASE_PREFIX=/internal
AGENT_WORKER_CONCURRENCY=2
AGENT_QUEUE_MAXSIZE=100
AGENT_POLL_INTERVAL_MS=500
AGENT_MAX_RETRIES=2
COMPETITOR_DATA_SOURCE=simulation
MARKET_COMPETITOR_MIN_VALID_COUNT=3

# LLM 备用默认值（用户未指定 base_url / model 时的回退）
# 注意：LLM_API_KEY 已不再需要，每个用户在前端「个人中心」自行配置
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen-plus

# 单次 LLM 调用的超时与重试控制
LLM_TIMEOUT_SECONDS=60
LLM_CONNECT_TIMEOUT_SECONDS=8
LLM_READ_TIMEOUT_SECONDS=25
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF_SECONDS=1.2

# CrewAI 中单次 LLM API 调用的超时与重试控制
CREWAI_LLM_TIMEOUT_SECONDS=60
CREWAI_LLM_CONNECT_TIMEOUT_SECONDS=8
CREWAI_LLM_READ_TIMEOUT_SECONDS=30
CREWAI_LLM_MAX_RETRIES=1

# CrewAI Agent 执行参数（本项目默认为串行执行）
CREWAI_MVP_ENABLED=true
FAST_AGENT_MAX_ITER=4
FAST_AGENT_MAX_EXEC_SECONDS=120
MANAGER_AGENT_MAX_ITER=6
MANAGER_AGENT_MAX_EXEC_SECONDS=180
CREWAI_AGENT_MAX_RETRY_LIMIT=1
CREWAI_SESSION_TIMEOUT_SECONDS=600
CREWAI_ENABLE_SECOND_ROUND=false
CREWAI_DEBUG_LOGS=false

# 市场情报是否启用模拟竞品样本
# 生产环境请设置为 false
MARKET_SIMULATION_ENABLED=true

# 本地或离线环境可关闭遥测
CREWAI_DISABLE_TELEMETRY=true
OTEL_SDK_DISABLED=true
