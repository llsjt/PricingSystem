# Public Beta 示例环境变量
#
# 使用方式：
# 1. 复制本文件为 `.env.public-beta`
# 2. 按注释替换所有 `replace-...` 占位值
# 3. dev / 本地联调可保留本机端口；prod / 公网部署必须替换密钥、令牌和域名

# 运行环境
# dev: 本地或内网联调
# prod: 公网部署，必须关闭开发兜底选项
APP_ENV=prod

# =========================
# 必填：生产环境必须替换
# =========================

# MySQL root 密码，必须替换
DB_PASSWORD=replace-with-strong-mysql-password

# Java JWT 访问令牌密钥，必须替换
JWT_SECRET=replace-with-long-jwt-secret

# Java JWT 刷新令牌密钥，必须替换
JWT_REFRESH_SECRET=replace-with-long-jwt-refresh-secret

# Java -> Python 内部调用令牌，两端必须一致，必须替换
INTERNAL_API_TOKEN=replace-with-internal-api-token

# Java / Python 共用的模型密钥加密密钥，必须长期稳定，必须替换
LLM_KEY_ENCRYPTION_SECRET=replace-with-base64-encoded-32-byte-secret

# 浏览器可访问来源
# dev 示例： http://localhost:8081,http://127.0.0.1:8081
# prod 示例： https://pricing.example.com
ALLOWED_ORIGINS=https://pricing.example.com

# =========================
# 可选：系统级模型兜底
# 正常业务优先使用用户在系统里保存的模型配置
# =========================
LLM_API_KEY=replace-with-llm-api-key-if-needed
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen-max

# =========================
# 可选：RabbitMQ 账号
# 若不填将回退到 compose 默认值
# 生产建议显式配置并替换
# =========================
RABBITMQ_USERNAME=pricingmq
RABBITMQ_PASSWORD=replace-with-rabbitmq-password
RABBITMQ_VHOST=/
RABBITMQ_WORKER_CONCURRENCY=1
RABBITMQ_PREFETCH=1

# =========================
# 开关项
# prod 建议：
# - ALLOW_DEV_BOOTSTRAP=false
# - SECURE_COOKIE=true
# =========================
ALLOW_DEV_BOOTSTRAP=false
SECURE_COOKIE=true
PROGRESS_PUBLISH_ENABLED=true

# =========================
# Python Worker / Java 调度参数
# 一般可直接使用默认值
# =========================
AGENT_WORKER_CONCURRENCY=2
AGENT_QUEUE_MAXSIZE=100
AGENT_POLL_INTERVAL_MS=500
AGENT_MAX_RETRIES=2
WORKER_MAX_RETRY=3
WORKER_RETRY_BACKOFF_MAX_SECONDS=30
PYTHON_AGENT_MAX_ATTEMPTS=3
PYTHON_AGENT_RETRY_BACKOFF_MS=300
PYTHON_AGENT_CIRCUIT_FAILURE_THRESHOLD=3
PYTHON_AGENT_CIRCUIT_OPEN_MS=30000

# =========================
# 本机端口
# 仅在宿主机端口冲突时修改
# =========================
MYSQL_PUBLIC_PORT=3307
RABBITMQ_PUBLIC_PORT=5673
RABBITMQ_MANAGEMENT_PUBLIC_PORT=15673
JAVA_PUBLIC_PORT=8080
FRONTEND_PUBLIC_PORT=8081
